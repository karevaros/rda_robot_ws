<?xml version="1.0"?>
<!--
  ⚠⚠ 사용 중단(2026-07-16). launch 는 더 이상 이 파일을 쓰지 않는다.
      통합 URDF 는 Python 컴포저가 만든다:
          ros2 run rda_robot_assembler compose_urdf --mounts <mounts.yaml>
      (rda_robot_assembler/composer.py — 조립기와 같은 모델 정의를 공유)

  이 파일을 되살려 쓰지 말 것. 두 가지 결함이 있다:
    ① 슬롯별 xacro:if 분기가 있는 7종만 반영하고, 나머지 21종은 **에러 없이 슬롯을
       통째로 누락**시킨다(아래 check_slot 방어는 그 누락을 즉시 실패로 바꾼 안전망일 뿐,
       분기를 늘려주지는 않는다).
    ② 아래 rb_6dof 호출이 벤더의 tcp_xyz="0 -0.0967 0" 을 넘기지 않아 매크로 기본값
       '0 0 0' 이 적용된다 → **tcp 가 96.7mm 틀린 자리(link6 원점)에 생긴다.**
       조립기는 벤더 standalone(robots/rb5_850e.urdf.xacro)을 쓰므로 정상이었고,
       그래서 앱 화면과 RViz 형상이 서로 달랐다. 컴포저는 같은 소스를 써서 일치한다.
  참고용으로만 남긴다.

  ---- 이하 원본 주석 ----

  rda_robot — 4개 파트 통합 URDF (mounts.yaml 기반, 모델 자동 스위칭)
  구성: ⓐ베이스(모바일) + ⓑ로봇팔 + ⓒ엔드이펙터(그리퍼) + ⓓ센서1·2

  ■ 모델/결합값 출처: config/mounts.yaml (rda_robot_assembler 앱이 저장)
    - models.base           : 베이스 모델 id
    - mounts.<slot>.model    : 팔/그리퍼/센서 모델 id
    - mounts.<slot>.parent_frame / xyz / rpy : 결합 위치
    → 앱 드롭다운에서 모델을 바꿔 저장하면 여기 통합 형상이 자동으로 바뀐다.

  ■ 새 모델 추가법: 해당 슬롯의 <xacro:if value="${...=='새id'}"> 블록을 복사해
    include(있으면)·mount joint·매크로 호출을 그 모델에 맞게 채운다.
    (각 모델은 매크로 인터페이스·루트 링크명이 달라 슬롯당 분기 블록이 필요하다.)
    ★ 분기를 추가했으면 아래 SUPPORTED_* 목록에도 그 id 를 반드시 넣을 것.

  ■ 지원 모델 한계(2026-07-16): 조립기 드롭다운에는 28종이 뜨지만, 통합 URDF 는 아래
    SUPPORTED_* 에 있는 7종만 반영한다. 지원 밖 모델을 고르면 xacro 가 조용히 슬롯을
    누락시켜 엉뚱한 곳(check_urdf/rsp)에서 터졌었다 → xacro.check_slot 으로 즉시 실패시킨다.
    폴백(기본모델로 조용히 대체)은 의도적으로 넣지 않는다: 고르지도 않은 형상 위에서
    도달권·SRDF·경로계획이 계산되는 게 기동 실패보다 위험하다.
    근본 해결은 Python URDF 컴포저(작업중) — 완료되면 이 한계와 방어는 사라진다.

  주의: RB5 는 rb_6dof prefix 버그로 무접두(link0..6). 상세: docs/파트규약-비교.md
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="rda_robot">

  <xacro:arg name="mounts_file" default="$(find rda_robot_description)/config/mounts.yaml"/>
  <xacro:property name="Y" value="${xacro.load_yaml('$(arg mounts_file)')}"/>
  <xacro:property name="M" value="${Y['mounts']}"/>
  <xacro:property name="SEL" value="${Y['models']}"/>

  <!-- ============ 슬롯 모델 방어 — 분기 없는 모델이면 즉시 실패 ============ -->
  <xacro:property name="SUPPORTED_BASE" value="${['scout_v2']}"/>
  <xacro:property name="SUPPORTED_ARM" value="${['rb5_850e']}"/>
  <xacro:property name="SUPPORTED_EE" value="${['onrobot_rg2']}"/>
  <xacro:property name="SUPPORTED_SENSOR" value="${['d405', 'd435i']}"/>

  <xacro:macro name="check_slot" params="slot name supported">
    <xacro:if value="${name not in supported}">
      ${xacro.fatal(
        slot + " 슬롯: 모델 '" + str(name) + "' 는 통합 URDF 에 반영할 수 없습니다"
        + " (해당 xacro:if 분기 없음)."
        + "  ■ 이 슬롯이 지원하는 모델: " + ', '.join(supported)
        + "  ■ 조치: config/mounts.yaml 에서 위 모델 중 하나로 바꾸거나,"
        + " Python URDF 컴포저(작업중) 완료 후 재시도하세요."
        + "  ※ 조립기 드롭다운의 28종이 곧 통합 URDF 지원 목록은 아닙니다."
      )}
    </xacro:if>
  </xacro:macro>

  <!-- ============ ⓐ 베이스(모바일) — models.base 로 스위칭 ============ -->
  <xacro:property name="bname" value="${SEL['base']}"/>
  <xacro:check_slot slot="base" name="${bname}" supported="${SUPPORTED_BASE}"/>
  <xacro:if value="${bname == 'scout_v2'}">
    <xacro:include filename="$(find scout_description)/urdf/scout_v2.xacro"/>
  </xacro:if>
  <!-- 새 베이스 추가:
  <xacro:if value="${bname == '새베이스id'}">
    <xacro:include filename="$(find 새패키지)/urdf/새베이스.xacro"/>
  </xacro:if>
  -->

  <!-- ============ ⓑ 로봇팔 — mounts.arm.model 로 스위칭 ============ -->
  <xacro:property name="am" value="${M['arm']}"/>
  <xacro:property name="aname" value="${am['model']}"/>
  <xacro:check_slot slot="arm" name="${aname}" supported="${SUPPORTED_ARM}"/>
  <xacro:if value="${aname == 'rb5_850e'}">
    <xacro:include filename="$(find rbpodo_description)/robots/rb_6dof.xacro"/>
    <joint name="arm_mount_joint" type="fixed">
      <parent link="${am['parent_frame']}"/>
      <child link="link0"/>
      <origin xyz="${am['xyz'][0]} ${am['xyz'][1]} ${am['xyz'][2]}"
              rpy="${am['rpy'][0]} ${am['rpy'][1]} ${am['rpy'][2]}"/>
    </joint>
    <xacro:rb_6dof model_id="rb5_850e" prefix="" tcp_name="tcp"/>
  </xacro:if>
  <!-- 새 팔 추가: include + arm_mount_joint(child=그 팔의 루트링크) + 그 팔 매크로 호출 -->

  <!-- ============ ⓒ 엔드이펙터 — mounts.endeffector.model 로 스위칭 ============ -->
  <xacro:property name="em" value="${M['endeffector']}"/>
  <xacro:property name="ename" value="${em['model']}"/>
  <xacro:check_slot slot="endeffector" name="${ename}" supported="${SUPPORTED_EE}"/>
  <xacro:if value="${ename == 'onrobot_rg2'}">
    <xacro:include filename="$(find rda_robot_description)/urdf/parts/endeffector/onrobot_rg2_macro.xacro"/>
    <xacro:onrobot_rg2 parent="${em['parent_frame']}" prefix="">
      <origin xyz="${em['xyz'][0]} ${em['xyz'][1]} ${em['xyz'][2]}"
              rpy="${em['rpy'][0]} ${em['rpy'][1]} ${em['rpy'][2]}"/>
    </xacro:onrobot_rg2>
  </xacro:if>
  <!-- 새 그리퍼 추가: include + 그 그리퍼 매크로 호출(parent=${em['parent_frame']}) -->

  <!-- ============ ⓓ 센서: RealSense (mounts.sensorN.model 로 스위칭) ============ -->
  <xacro:include filename="$(find realsense2_description)/urdf/_d405.urdf.xacro"/>
  <xacro:include filename="$(find realsense2_description)/urdf/_d435i.urdf.xacro"/>

  <xacro:macro name="mount_sensor" params="key">
    <xacro:property name="s" value="${M[key]}"/>
    <xacro:property name="sname" value="${s['model']}"/>
    <xacro:check_slot slot="${key}" name="${sname}" supported="${SUPPORTED_SENSOR}"/>
    <xacro:if value="${sname == 'd405'}">
      <xacro:sensor_d405 parent="${s['parent_frame']}" name="${sname}" use_nominal_extrinsics="true">
        <origin xyz="${s['xyz'][0]} ${s['xyz'][1]} ${s['xyz'][2]}"
                rpy="${s['rpy'][0]} ${s['rpy'][1]} ${s['rpy'][2]}"/>
      </xacro:sensor_d405>
    </xacro:if>
    <xacro:if value="${sname == 'd435i'}">
      <xacro:sensor_d435i parent="${s['parent_frame']}" name="${sname}" use_nominal_extrinsics="true">
        <origin xyz="${s['xyz'][0]} ${s['xyz'][1]} ${s['xyz'][2]}"
                rpy="${s['rpy'][0]} ${s['rpy'][1]} ${s['rpy'][2]}"/>
      </xacro:sensor_d435i>
    </xacro:if>
  </xacro:macro>

  <xacro:mount_sensor key="sensor1"/>
  <xacro:mount_sensor key="sensor2"/>

</robot>
