<?xml version="1.0"?>
<!--
  rda_robot — 4개 파트 통합 URDF 초안 (2주차 산출물)
  구성: ⓐScout 2.0(모바일, 루트) + ⓑRB5-850e(팔) + ⓒOnRobot RG2(그리퍼)
        + ⓓD405(eye-in-hand) + D435i(eye-to-hand)
  주의:
    - mount origin(장착 위치/자세)은 도면 확정 전 초안 추정값 = TODO.
    - RB5는 rb_6dof 매크로 prefix 버그로 무접두(link0..6,tcp) 사용. 상세: docs/파트규약-비교.md
  검증: xacro→urdf, check_urdf 단일 트리, RViz2 표시.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="rda_robot">

  <!-- ============ ⓐ 모바일: Scout 2.0 (매크로 아님 → base_link 루트 직접 정의) ============ -->
  <xacro:include filename="$(find scout_description)/urdf/scout_v2.xacro"/>

  <!-- ============ ⓑ 로봇팔: RB5-850e ============ -->
  <xacro:include filename="$(find rbpodo_description)/robots/rb_6dof.xacro"/>
  <!-- TODO: 실제 팔 장착 위치(스카웃 상판 높이/오프셋) 확정 필요 -->
  <joint name="arm_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="link0"/>
    <origin xyz="0.0 0.0 0.25" rpy="0 0 0"/>
  </joint>
  <xacro:rb_6dof model_id="rb5_850e" prefix="" tcp_name="tcp"/>

  <!-- ============ ⓒ 엔드이펙터: OnRobot RG2 (팔 tcp 에 부착) ============ -->
  <xacro:include filename="$(find rda_robot_description)/urdf/parts/endeffector/onrobot_rg2_macro.xacro"/>
  <!-- TODO: 실제 플랜지-그리퍼 어댑터 오프셋 확정 필요 -->
  <xacro:onrobot_rg2 parent="tcp" prefix="">
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </xacro:onrobot_rg2>

  <!-- ============ ⓓ 센서 1: D405 (eye-in-hand, 그리퍼 손목에 부착) ============ -->
  <xacro:include filename="$(find realsense2_description)/urdf/_d405.urdf.xacro"/>
  <!-- TODO: 실제 eye-in-hand 브래킷 위치 확정 필요 -->
  <xacro:sensor_d405 parent="rg2_hand" name="d405" use_nominal_extrinsics="true">
    <origin xyz="0.02 0.0 0.03" rpy="0 0 0"/>
  </xacro:sensor_d405>

  <!-- ============ ⓓ 센서 2: D435i (eye-to-hand, 베이스 마스트에 부착) ============ -->
  <xacro:include filename="$(find realsense2_description)/urdf/_d435i.urdf.xacro"/>
  <!-- 초안 마스트: 베이스 위 고정 프레임 (TODO: 실제 마스트 형상/높이) -->
  <link name="sensor_mast"/>
  <joint name="mast_joint" type="fixed">
    <parent link="base_link"/>
    <child link="sensor_mast"/>
    <origin xyz="-0.25 0.0 0.6" rpy="0 0.3 0"/>
  </joint>
  <xacro:sensor_d435i parent="sensor_mast" name="d435i" use_nominal_extrinsics="true">
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </xacro:sensor_d435i>

</robot>
