<?xml version="1.0"?>
<!-- rda_robot_assembler/mesh2urdf 가 자동 생성. 원본: box_base.stl
     강체 1링크(관절 없음). 관절이 필요하면 전용 CAD 익스포터를 쓰세요. -->
<robot name="box_base">
  <link name="box_base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/box_base_visual.stl"/>
      </geometry>
      <material name="box_base_material">
        <color rgba="0.75 0.75 0.78 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/box_base_collision.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.000000 0.000000 0.050000" rpy="0 0 0"/>
      <mass value="64.800000"/>
      <inertia ixx="0.91800000" ixy="-0.00000000" ixz="-0.00000000" iyy="1.99800000" iyz="-0.00000000" izz="2.80800000"/>
    </inertial>
  </link>
</robot>
