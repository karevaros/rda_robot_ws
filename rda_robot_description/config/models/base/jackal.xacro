<?xml version="1.0"?>
<!-- Clearpath j100 인스턴스화 래퍼.
     상류 j100.urdf.xacro 는 <xacro:macro name="j100"> 정의만 있고
     인스턴스화를 안 해서 그대로 처리하면 링크가 0개다. 이 래퍼가 매크로를 호출한다. -->
<robot xmlns:xacro="http://ros.org/wiki/xacro" name="jackal">
  <xacro:include filename="$(find clearpath_platform_description)/urdf/j100/j100.urdf.xacro"/>
  <xacro:j100/>
</robot>
