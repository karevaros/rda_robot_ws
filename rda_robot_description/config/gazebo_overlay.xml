<!-- ===================================================================
     Gazebo Classic 오버레이 (Stage 1) — gazebo_sim.launch.py 가 통합 URDF 의
     </robot> 앞에 자동 주입한다. 통합 URDF(compose_urdf 산출물)는 손대지 않음.

     · 로봇 = static: perception 카메라 플랫폼이라 물리 구동 불필요 → 관성 누락(base_link·
       link0) 무해, 팔이 중력에 흐트러지지 않고 스폰 자세 유지.
     · D435i(eye-to-hand) depth 카메라 → PointCloud2 + depth 이미지 + camera_info.
       센서는 sensor2_camera_link 에 부착(메시 있는 본체라 SDF 변환 시 살아남음; Gazebo 는
       링크 로컬 +X 로 바라봄 = RealSense camera_link 의 렌즈 방향). 출력 frame_id =
       depth optical frame(ROS 광학 규약, Z-forward).
     ================================================================ -->

<gazebo>
  <static>true</static>
</gazebo>

<gazebo reference="sensor2_camera_link">
  <sensor name="d435i_depth" type="depth">
    <always_on>true</always_on>
    <update_rate>15.0</update_rate>
    <visualize>true</visualize>
    <camera name="d435i">
      <horizontal_fov>1.5009</horizontal_fov>   <!-- D435 depth ~86° -->
      <image>
        <width>640</width>
        <height>480</height>
        <format>R8G8B8</format>
      </image>
      <clip>
        <near>0.1</near>
        <far>10.0</far>
      </clip>
    </camera>
    <plugin name="d435i_camera" filename="libgazebo_ros_camera.so">
      <ros>
        <namespace>/d435i</namespace>
      </ros>
      <camera_name>depth</camera_name>
      <frame_name>sensor2_camera_depth_optical_frame</frame_name>
      <min_depth>0.1</min_depth>
      <max_depth>10.0</max_depth>
    </plugin>
  </sensor>
</gazebo>

<!-- D405(eye-in-hand, 그리퍼 손등) — 손끝 근접 뷰. D435i(전역)가 못 보는 잎/줄기 뒤
     사각지대를 메운다. MoveIt 은 센서를 여러 개 받아 **하나의 옥토맵을 공동 갱신**한다
     (sensors_3d.yaml 의 sensors 목록).
     ⚠ 현재 로봇은 <static>true</static> 라 Gazebo 안에서 팔이 안 움직인다 → 이 카메라
       시점도 스폰 자세에 고정이다. 진짜 '팔이 움직이며 실시간 갱신'은 6주차(ros2_control
       로 Gazebo 관절 구동)부터. 그때 이 블록은 그대로 두면 자동으로 실시간이 된다.
     ⚠ 그때까지 /joint_states 재생(pregrasp_demo)과 이 시뮬을 **같이 돌리지 말 것** —
       TF 상 팔은 움직이는데 Gazebo 렌더는 고정이라 클라우드가 엉뚱한 자세로 투영돼
       옥토맵이 오염된다. -->
<gazebo reference="sensor1_camera_link">
  <sensor name="d405_depth" type="depth">
    <always_on>true</always_on>
    <update_rate>15.0</update_rate>
    <visualize>true</visualize>
    <camera name="d405">
      <horizontal_fov>1.5184</horizontal_fov>   <!-- D405 depth ~87° -->
      <image>
        <width>640</width>
        <height>480</height>
        <format>R8G8B8</format>
      </image>
      <clip>
        <!-- D405 는 근접 전용(제원 7cm~50cm, 실사용 ~1m). 멀리까지 열어두면 전역
             카메라와 중복 데이터만 늘고 근접 정확도 이점이 사라진다. -->
        <near>0.05</near>
        <far>1.0</far>
      </clip>
    </camera>
    <plugin name="d405_camera" filename="libgazebo_ros_camera.so">
      <ros>
        <namespace>/d405</namespace>
      </ros>
      <camera_name>depth</camera_name>
      <frame_name>sensor1_camera_depth_optical_frame</frame_name>
      <min_depth>0.05</min_depth>
      <max_depth>1.0</max_depth>
    </plugin>
  </sensor>
</gazebo>
